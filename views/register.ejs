<% layout('layout', { title: 'Create Account', userId: null }) %>

<div class="card">
  <div style="margin-bottom: 25px;">
    <h2 style="font-size: 1.5rem; color: #0f172a;">Sign Up</h2>
  </div>

  <form method="POST" action="/register">
    <div class="input-group">
      <label>Username</label>
      <div class="input-wrapper">
        <input type="text" name="username"  required>
      </div>
    </div>

    <div class="input-group">
      <label>Password</label> 
      <div class="input-wrapper">
     
        <input type="password" name="password" required>
      </div>
    </div>

    <button type="submit" style="margin-top: 15px;">
      Create Account <i class="fas fa-arrow-right"></i>
    </button>
  </form>

  <p style="margin-top: 25px; font-size: 0.9rem; color: #64748b;">
    Already have an account? <a href="/login" style="color: var(--primary); text-decoration: none; font-weight: 600;">Log in</a>
  </p>
</div>